# Настройки LLM API (Groq / OpenRouter / OpenAI)
LLM_API_KEY=
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.3-70b-versatile

# Настройки ASR (Whisper)
# Возможные значения: tiny, base, small, medium, large-v3
# Для запуска на CPU рекомендуется "small" или "medium".
WHISPER_MODEL=small

# Настройки сетевых портов
API_PORT=8000
OPENWEBUI_PORT=3000

# Логирование
LOG_LEVEL=INFO
